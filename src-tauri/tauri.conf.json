{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kids Cam",
  "version": "0.0.3",
  "identifier": "com.familia.kidscam",
  "build": {
    "frontendDist": "view",
    "devUrl": "http://localhost:3006",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kids-cam",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 470,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1QTY3QjJCMUE4NzAzOEQKUldTTkE0Y2FLM3VtVlRRSzlxRVU1dU5VdkxzVjZlcEI1dGZzYThjRW1vMHpQaERJckdJS21HSnMK",
      "endpoints": [
        "https://github.com/RafaZeero/family-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "PortugueseBR"
        ],
        "installMode": "currentUser"
      }
    }
  }
}
